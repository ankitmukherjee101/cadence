APP_ENV=development
CORS_ORIGINS=*

# Supabase (JWT validation — use JWT secret from Project Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_JWT_SECRET=

GROQ_API_KEY=
DEEPGRAM_API_KEY=

NEO4J_URI=
# Driver accepts NEO4J_USERNAME or NEO4J_USER (Aura often labels this “username”)
NEO4J_USERNAME=
NEO4J_PASSWORD=
# Optional: default Neo4j DB name is usually "neo4j" on Aura; set if you use a different database
NEO4J_DATABASE=
# Optional: copy from Aura console for your notes; not required for the Python driver today
AURA_INSTANCEID=
AURA_INSTANCENAME=